# Ansible Vault Template for Production Secrets
#
# INSTRUCTIONS:
# 1. Copy this file: cp vault.yml.example vault.yml
# 2. Edit with your actual secrets (replace CHANGE_ME values)
# 3. Encrypt: ansible-vault encrypt vault.yml
# 4. Never commit unencrypted vault.yml to Git
#
# Generate secure secrets:
#   DB Password: openssl rand -base64 32
#   JWT Secret:  openssl rand -hex 64

---
# PostgreSQL Database Credentials
vault_db_password: "CHANGE_ME_SECURE_RANDOM_PASSWORD"

# JWT Authentication Secret (256-bit minimum)
vault_jwt_secret_key: "CHANGE_ME_RANDOM_KEY_64_CHARS_HEX"

# Future third-party API keys (Phase 2+)
# vault_external_api_key: "CHANGE_ME_IF_NEEDED"
